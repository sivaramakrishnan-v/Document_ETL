{
  "family": "documentetl-smoke-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::054037138513:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "documentetl",
      "image": "054037138513.dkr.ecr.us-east-1.amazonaws.com/documentetl-app:latest",
      "essential": true,
      "entryPoint": [
        "sh",
        "-c"
      ],
      "command": [
        "echo DocumentETL ECS smoke test started; java -version; sleep 300"
      ],
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/documentetl-app",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
